# SSH connection (use password OR private key)
SSH_HOST=127.0.0.1
SSH_PORT=22
SSH_USERNAME=linuxgsm
SSH_PASSWORD=change-me
# SSH_PRIVATE_KEY_PATH=C:/keys/id_rsa
# SSH_PRIVATE_KEY_PASSPHRASE=

# LinuxGSM Project Zomboid location/command
PZ_SERVER_DIR=/home/linuxgsm
PZ_LGSM_SCRIPT=./pzserver
PZ_SENDSERVERMSG_COMMAND_TEMPLATE=./pzserver send-servermsg {message}

# Scheduler
PZ_ANNOUNCEMENT_CRON=0 * * * *
PZ_ANNOUNCEMENT_TIMEZONE=Asia/Jakarta
PZ_ANNOUNCEMENT_RUN_ON_START=true

# Pipe-separated announcement list
PZ_ANNOUNCEMENTS=[Zona Merah] Dummy announcement #1: Stay alert survivors, secure your base before nightfall.|[Zona Merah] Dummy announcement #2: Join Discord for latest events, wipes, and server updates.

# Frontend API integration (Vite)
# Example: http://74.63.203.203:3000
VITE_ZM_API_BASE_URL=http://127.0.0.1:3000
# Use /api/flea-market/listings for listings data.
# If you use /api/flea-market, frontend will auto-fallback to /listings.
VITE_ZM_FLEA_MARKET_ENDPOINT=/api/flea-market/listings

# Frontend Auth API endpoints
VITE_ZM_AUTH_LOGIN_ENDPOINT=/api/auth/login
VITE_ZM_AUTH_REGISTER_ENDPOINT=/api/auth/register
VITE_ZM_AUTH_ME_ENDPOINT=/api/auth/me
VITE_ZM_AUTH_DISCORD_URL_ENDPOINT=/api/auth/discord/url
VITE_ZM_AUTH_DISCORD_EXCHANGE_ENDPOINT=/api/auth/discord/exchange
VITE_ZM_AUTH_DISCORD_REGISTER_ENDPOINT=/api/auth/discord/register

# User detail profile management endpoints
VITE_ZM_USER_DETAIL_ME_ENDPOINT=/api/user-details/me
VITE_ZM_USER_DETAIL_AVATAR_ENDPOINT=/api/user-details/me/avatar
VITE_ZM_USER_DETAIL_STATUSES_ENDPOINT=/api/user-details/statuses
VITE_ZM_USER_DETAIL_SYNC_GAME_STATUS_ENDPOINT=/api/user-details/me/sync-game-status
